# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude terraform.tfvars and *.auto.tfvars if they contain secrets.
# (Uncomment the line below if you want to keep secrets out of Git)
# terraform.tfvars

# Ignore override files as they may contain local-only configuration
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include plugin cache directory
.terraform.lock.hcl

# Include CLI web browser auth token cache
.terraform.d/
